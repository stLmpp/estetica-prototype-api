{
  "name": "wg-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "migrations:build:main": "tsx scripts/build-drizzle-kit-configs.ts",
    "migrations:generate:main": "drizzle-kit generate --config=migrations/dist/main-drizzle.config.js",
    "migrations:run:main": "drizzle-kit migrate --config=migrations/dist/main-drizzle.config.js",
    "migrations:run:auth": "pnpm dlx auth@latest migrate --config dist/auth/auth.js --yes",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs-cls/transactional": "~3.2.1",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "~1.3.0",
    "@nestjs/common": "~11.1.27",
    "@nestjs/core": "~11.1.27",
    "@nestjs/platform-express": "~11.1.27",
    "@nestjs/schedule": "~6.1.3",
    "@nestjs/swagger": "~11.4.4",
    "@nestjs/throttler": "~6.5.0",
    "@swc/helpers": "~0.5.23",
    "@thallesp/nestjs-better-auth": "~2.6.1",
    "@tygra/nestjs-graceful-shutdown": "~2.0.0",
    "better-auth": "~1.6.20",
    "compression": "~1.8.1",
    "dayjs": "~1.11.21",
    "dotenv": "~17.4.2",
    "drizzle-orm": "1.0.0-rc.3",
    "helmet": "~8.2.0",
    "nestjs-cls": "~6.2.1",
    "nestjs-zod": "~5.4.0",
    "pg": "~8.22.0",
    "pino": "~10.3.1",
    "pino-pretty": "~13.1.3",
    "pino-roll": "~4.0.0",
    "pretty-ms": "^9.3.0",
    "reflect-metadata": "~0.2.2",
    "rxjs": "~7.8.2",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "~3.3.5",
    "@eslint/js": "~10.0.1",
    "@nestjs/cli": "~11.0.23",
    "@nestjs/schematics": "~11.1.0",
    "@nestjs/testing": "~11.1.27",
    "@swc/cli": "~0.8.1",
    "@swc/core": "~1.15.43",
    "@types/compression": "~1.8.1",
    "@types/express": "~5.0.6",
    "@types/jest": "~30.0.0",
    "@types/node": "~22.19.17",
    "@types/pg": "~8.20.0",
    "@types/supertest": "~7.2.0",
    "@types/ws": "~8.18.1",
    "drizzle-kit": "1.0.0-rc.4-ca0f029",
    "esbuild": "~0.28.1",
    "eslint": "~10.5.0",
    "glob": "~13.0.6",
    "globals": "~17.7.0",
    "jest": "~30.4.2",
    "openapi-types": "~12.1.3",
    "prettier": "~3.8.4",
    "prettier-plugin-multiline-arrays": "~4.1.9",
    "source-map-support": "~0.5.21",
    "supertest": "~7.2.2",
    "ts-jest": "~29.4.11",
    "ts-loader": "~9.6.2",
    "ts-node": "~10.9.2",
    "tsconfig-paths": "~4.2.0",
    "tsx": "~4.22.4",
    "type-fest": "~5.7.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "~8.62.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "~.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
